{
  "name": "mdl-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "next dev",
    "server": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "doctor": "npx react-doctor@latest",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "predev": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "start_fe_and_be": "concurrently -k -n FRONTEND,BACKEND -c blue,green \"pnpm dev\" \"pnpm exec trigger dev\"",
    "typecheck": "rimraf tsconfig.tsbuildinfo && tsc --noEmit"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@sentry/nextjs": "^10",
    "@supabase/realtime-js": "^2.110.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@trigger.dev/sdk": "^4.5.4",
    "@vercel/analytics": "^2.0.1",
    "animejs": "^4.4.1",
    "archiver": "^8.0.0",
    "async_hooks": "^1.0.0",
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.2",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-auth": "^4.24.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "typescript-eslint": "^8.60.1",
    "undici-types": "^8.4.1",
    "websocket": "^1.0.35",
    "zod": "^4.4.3",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@trigger.dev/build": "^4.5.4",
    "@types/archiver": "^8.0.0",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "postcss": "^8.0.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.0.0",
    "trigger.dev": "4.5.4",
    "typescript": "^5.0.0",
    "ws": "8.21.0"
  }
